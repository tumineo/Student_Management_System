@model IEnumerable<StudentManagement.Models.Student>

@{
    ViewData["Title"] = "Students List";
}

<h1>Students</h1>

<table class="table">
    <thead>
        <tr>
            <th>Full Name</th>
            <th>Email</th>
            <th>Image</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>@item.FullName</td>
            <td>@item.Email</td>
            <td>
                <img src="@item.ImagePath" alt="Student Image" width="100" height="100" />
            </td>
            <td>
                <a asp-action="Details" asp-route-id="@item.Id">View</a>
            </td>
        </tr>
}
    </tbody>
</table>
